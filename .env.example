# pApAmA — environment variables (example). Copy to .env.local and fill in.
# .env.local is git-ignored; NEVER commit real secrets.

# --- Supabase ----------------------------------------------------------------
# Public (safe for the browser):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (NEVER expose to the client / NEXT_PUBLIC_):
SUPABASE_SERVICE_ROLE_KEY=

# --- Token QR signing (server-only) ------------------------------------------
# HMAC secret for one-time token QR payloads (app/api/_lib/tokenQr.ts). Set this
# to a long random value and NEVER rotate it, or every already-issued token QR
# becomes unverifiable. Falls back to SUPABASE_SERVICE_ROLE_KEY when unset (so it
# keeps working pre-launch), but a dedicated secret is strongly preferred.
TOKEN_QR_SECRET=

# --- UPI manual QR donation (self-hosted, no payment-provider SDK) ------------
# Merchant VPA the donation QR collects to (e.g. yourorg@okhdfcbank). REQUIRED in
# production — without it the generate route falls back to a clearly-flagged demo
# VPA ("papama@upi") that is NOT a real collecting account. (ASSUMPTIONS.md)
NEXT_PUBLIC_UPI_VPA=
# Payee name shown in the UPI app:
NEXT_PUBLIC_UPI_MERCHANT_NAME=pApAmA Community Meals
# Optional UPI merchant category code:
NEXT_PUBLIC_UPI_MERCHANT_CODE=
# Optional prefix for generated transaction references (default: PAPAMA):
UPI_TX_PREFIX=PAPAMA

# --- Donor mock mode (offline demo) ------------------------------------------
# 'true' routes the donor ApiClient to the in-browser mock DB instead of the real
# same-origin routes. Leave unset/false for the real backend.
NEXT_PUBLIC_USE_MOCK_API=

# --- Payment & email providers (OPEN ITEMS — ASSUMPTIONS.md) ------------------
# Card / netbanking provider (Razorpay / Cashfree / PhonePe) and the
# transactional EMAIL provider are NOT yet chosen. They remain clearly-flagged
# MOCK seams in code — do NOT add real provider keys until the mentor decides.
