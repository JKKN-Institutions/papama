# Supabase Configuration (Example - Do NOT add real keys!)
# Copy this file to .env.local and fill in your actual values from Supabase Dashboard

# Public API (Safe for frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (BACKEND ONLY - NEVER expose to client)
# Only use in server-side code (API routes, server components)
# ⚠️ KEEP THIS SECRET - Never commit to git
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
